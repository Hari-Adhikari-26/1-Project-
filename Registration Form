*{
    margin: 0;
    padding: 0;
}

body{
    background-image: url("web.jpg");
    background-position: 400px 0px;
    background-size: cover;
    color: black;
}

button {
    color: wheat;
    font-family: "Britannic Bold", sans-serif;
    background-color: hotpink;
    width: 100%;
    height: 50px;
    border-radius: 20px;
    transition: 0.3s;
    box-shadow: horizontal vertical blur spread color;

}

button:hover{
    transform: scale(1.1);
    background-color: rgba(235, 105, 255, 0.329);
}

.first{
    width: 400px;
    margin: 100px auto;
    background-color: #f4b6c2;
    border-radius: 10px;
}

h2{
    padding: 20px;
    color: white;
    font-family: Arial, sans-serif;
    font-weight: bold;
    text-align: center;
}

label{
    font-family: Arial, Helvetica, sans-serif;
    font-style: italic;
    margin: 15px;
}

input#first {
    width: 300px;
    height: 40px;
}

form{
    margin: 40px;
}

input{
    width: 90%;
    height: 30px;
    border-radius: 10px;
    margin: 10px;
    padding: 5px;
}
.gender {
    display: flex;
    align-items: center;
    gap: 15px; /* space between items */
}

input:hover {
    border: 5px solid hotpink;
    
}






